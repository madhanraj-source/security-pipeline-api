# ============================================================
# Modern AI Security Pipeline — Environment Variables
# cp .env.example .env  then fill in your values
# No quotes, no trailing comments, no empty lines
# ============================================================
GAUSS_API_URL=https://YOUR_SAMSUNG_DOMAIN
GAUSS_CLIENT_KEY=your-client-key
GAUSS_PASS_KEY=Bearer your-full-token
GAUSS_MODEL_ID=your-model-id
GAUSS_EMAIL=your-email@samsung.com
REPORT_DIR=./reports
DASHBOARD_PORT=8501
