# ============================================================
# AI Security Pipeline (Office) — Environment Variables
# cp .env.example .env  then fill in your values
# No quotes, no trailing comments on value lines
# ============================================================

# Samsung Gauss API
GAUSS_API_URL=https://YOUR_SAMSUNG_DOMAIN
GAUSS_CLIENT_KEY=your-client-key
GAUSS_PASS_KEY=your-pass-key
GAUSS_MODEL_ID=your-model-id
GAUSS_EMAIL=your-email@samsung.com

# SonarQube
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=your-sonarqube-project-token
SONAR_PROJECT_KEY=your-project-key
SONAR_USER=admin
SONAR_PASSWORD=your-sonarqube-password

# Pipeline settings
REPORT_DIR=./reports
CODEQL_DB=./codeql-db
DASHBOARD_PORT=8501
