@charset "utf-8";

:root { --color-bg: #0A0A0A; --color-text: #E2FFE8; --glow-color-rgb: 0,255,65; }

*, ::before, ::after { box-sizing: border-box; }

html, body { background: var(--color-bg); margin: 0px; }

body { font-family: Inter, sans-serif; color: var(--color-text); overflow: hidden; height: 100vh; width: 100vw; }

.deck { width: 100vw; height: 100vh; position: relative; }

.slide { position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; background: var(--color-bg); display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0; transform: scale(0.97); transition: opacity 0.65s, transform 0.65s; pointer-events: none; overflow: hidden; }

.slide.active { opacity: 1; transform: scale(1); pointer-events: all; }

.slide > .content { position: relative; z-index: 2; width: 100%; max-width: 1100px; padding: clamp(1.5rem, 3.5vw, 3.5rem); }

.nav-controls { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%); display: flex; align-items: center; gap: 16px; z-index: 100; background: rgba(0, 255, 65, 0.04); backdrop-filter: blur(12px); padding: 10px 24px; border-radius: 40px; border: 1px solid rgba(0, 255, 65, 0.15); }

.nav-btn { width: 38px; height: 38px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; background: rgba(0, 255, 65, 0.06); color: rgb(0, 255, 65); border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.3s; }

.nav-btn:hover { background: rgba(0, 255, 65, 0.15); }

.slide-dots { display: flex; gap: 8px; }

.slide-dots .dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(0, 255, 65, 0.2); cursor: pointer; transition: background 0.3s, transform 0.3s; }

.slide-dots .dot.active { background: rgb(0, 255, 65); transform: scale(1.35); }

.slide-counter { font-size: 0.75rem; color: rgb(90, 138, 98); min-width: 40px; text-align: center; font-family: "JetBrains Mono", monospace; }

.reveal { opacity: 0; transform: translateY(18px); }

.text-glow { text-shadow: rgba(0, 255, 65, 0.55) 0px 0px 18px, rgba(0, 255, 65, 0.2) 0px 0px 36px; }

.stat-glow { text-shadow: rgba(0, 255, 65, 0.65) 0px 0px 28px, rgba(0, 255, 65, 0.25) 0px 0px 55px; }

@keyframes glow-pulse { 
  0%, 100% { text-shadow: rgba(0, 255, 65, 0.5) 0px 0px 18px, rgba(0, 255, 65, 0.2) 0px 0px 36px; }
  50% { text-shadow: rgba(0, 255, 65, 0.9) 0px 0px 30px, rgba(0, 255, 65, 0.35) 0px 0px 60px; }
}

.glow-pulse { animation: 2.8s ease-in-out 0s infinite normal none running glow-pulse; }

@keyframes float-slow { 
  0% { transform: translate(0px, 0px) scale(1); }
  25% { transform: translate(55px, -45px) scale(1.1); }
  50% { transform: translate(-35px, 38px) scale(0.92); }
  75% { transform: translate(48px, 18px) scale(1.07); }
  100% { transform: translate(0px, 0px) scale(1); }
}

@keyframes float-drift { 
  0% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
  33% { transform: translate(-48px, -55px) scale(1.14) rotate(3deg); }
  66% { transform: translate(38px, 28px) scale(0.87) rotate(-2deg); }
  100% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
}

@keyframes float { 
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-14px); }
}

.gradient-mesh { position: absolute; inset: 0px; z-index: 0; overflow: hidden; pointer-events: none; }

.blob { position: absolute; border-radius: 50%; filter: blur(80px); animation: 10s ease-in-out 0s infinite normal none running float-slow; }

.blob:nth-child(2) { animation: 14s ease-in-out 0s infinite normal none running float-drift; }

.blob:nth-child(3) { animation: 18s ease-in-out 0s infinite reverse none running float-slow; }

.slide::before { content: ""; position: absolute; inset: 0px; z-index: 1; pointer-events: none; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"); background-repeat: repeat; background-size: 256px 256px; opacity: 0.04; mix-blend-mode: overlay; }

.slide::after { content: ""; position: absolute; inset: 0px; z-index: 1; pointer-events: none; background: radial-gradient(transparent 45%, rgba(0, 0, 0, 0.55) 100%); }

.scanlines { position: absolute; inset: 0px; z-index: 1; pointer-events: none; background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 255, 65, 0.016) 2px, rgba(0, 255, 65, 0.016) 4px); }

.grid-bg { position: absolute; inset: 0px; z-index: 0; pointer-events: none; background-image: linear-gradient(rgba(0, 255, 65, 0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 255, 65, 0.04) 1px, transparent 1px); background-size: 60px 60px; }

.glass-card { background: rgba(0, 255, 65, 0.04); backdrop-filter: blur(10px); border: 1px solid rgba(0, 255, 65, 0.12); border-radius: 12px; }

.accent-card { border-left: 3px solid rgb(0, 255, 65); background: rgba(0, 255, 65, 0.03); border-radius: 0px 10px 10px 0px; }

.orange-card { border-left: 3px solid rgb(255, 165, 0); background: rgba(255, 165, 0, 0.04); border-radius: 0px 10px 10px 0px; }

.bar-track { background: rgba(0, 255, 65, 0.08); border-radius: 4px; height: 22px; overflow: hidden; }

.bar-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, rgb(0, 255, 65), rgb(0, 204, 51)); width: 0%; transition: width 0.8s; }

.stat-line { display: flex; align-items: baseline; gap: 0.35rem; }

.pipeline-node { display: flex; flex-direction: column; align-items: center; gap: 4px; }

.pipeline-arrow { color: rgb(0, 255, 65); font-size: 1.1rem; line-height: 1; }

.badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.65rem; font-family: "JetBrains Mono", monospace; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; }

.badge-green { background: rgba(0, 255, 65, 0.12); color: rgb(0, 255, 65); border: 1px solid rgba(0, 255, 65, 0.25); }

.badge-orange { background: rgba(255, 165, 0, 0.12); color: rgb(255, 165, 0); border: 1px solid rgba(255, 165, 0, 0.3); }

.badge-red { background: rgba(255, 80, 80, 0.12); color: rgb(255, 80, 80); border: 1px solid rgba(255, 80, 80, 0.3); }

.deco-shape { position: absolute; border-radius: 50%; pointer-events: none; }

.mouse-spotlight { position: fixed; inset: 0px; z-index: 99; pointer-events: none; }

@media (prefers-reduced-motion: reduce) {
  *, ::before, ::after { animation-duration: 0.01ms !important; transition-duration: 0.2s !important; }
}
